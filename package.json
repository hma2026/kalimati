{
  "name": "kalimati",
  "version": "0.7.9",
  "private": true,
  "type": "module",
  "description": "كلمة كلمة — أداة مساعدة للتواصل والتدريب على النطق (PWA). لا تغني عن المختصين.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -p tsconfig.json",
    "check:assets": "node tools/extract-assets/coverage_check.mjs && node tools/extract-assets/check_no_emoji_ui.mjs",
    "check:no-emoji-ui": "node tools/extract-assets/check_no_emoji_ui.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1"
  }
}